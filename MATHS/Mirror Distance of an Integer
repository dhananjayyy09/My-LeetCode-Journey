class Solution {
public:
    int reversee(int num){
        int rev = 0;
        while(num > 0){
            int last = num % 10;
            rev = (rev * 10) + last;
            num /= 10;
        }
        return rev;
    }

    int mirrorDistance(int n) {
        int rev = reversee(n);
        return abs(n - rev);
    }
};
