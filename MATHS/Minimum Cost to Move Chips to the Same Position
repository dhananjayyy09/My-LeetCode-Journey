class Solution {
public:
    int minCostToMoveChips(vector<int>& position) {
        int n = position.size();
        int odd = 0, even = 0;
        for(auto it : position){
            if(it % 2 == 0) even++;
            else odd++;
        }

        if(odd >= even) return n - odd;
        return n - even;
    }
};
