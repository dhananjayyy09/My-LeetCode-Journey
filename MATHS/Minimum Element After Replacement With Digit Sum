class Solution {
public:
    int getSum(int num){
        int sum = 0;
        while(num > 0){
            sum += num % 10;
            num /= 10;
        }
        return sum;
    }

    int minElement(vector<int>& nums) {
        int n = nums.size();
        int mini = 1e9;
        for(int i = 0; i < n; i++){
            int sum = getSum(nums[i]);
            mini = min(mini, sum);
        }
        return mini;
    }
};
