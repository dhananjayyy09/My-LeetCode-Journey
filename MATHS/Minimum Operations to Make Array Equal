class Solution {
public:
    int minOperations(int n) {
        vector<int> arr(n);
        for(int i = 0; i < n; i++){
            arr[i] = 2*i + 1;
        }

        int target;
        if(n % 2 == 1) target = arr[n/2];
        else target = (arr[n/2 - 1] + arr[n/2]) / 2;

        int ops = 0;
        for(int i = 0; i < n/2; i++){
            ops += target - arr[i];
        }
        return ops;
    }
};
