class Solution {
public:
    int findGCD(vector<int>& nums) {
        int n = nums.size();
        int maxi = nums[0], mini = nums[0];
        for(int i = 1; i < n; i++){
            maxi = max(maxi, nums[i]);
            mini = min(mini, nums[i]);
        }
        return gcd(mini, maxi);
    }
};
