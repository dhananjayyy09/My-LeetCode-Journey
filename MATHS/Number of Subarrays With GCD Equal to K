class Solution {
public:
    int subarrayGCD(vector<int>& nums, int k) {
        int n = nums.size();
        int count = 0;
        for(int i = 0; i < n; i++){
            int curGCD = nums[i];
            for(int j = i; j < n; j++){
                curGCD = gcd(curGCD, nums[j]);
                if(curGCD == k) count++; 
            }
        }
        return count;
    }
};
