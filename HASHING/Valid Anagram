class Solution {
public:
    bool isAnagram(string s, string t) {
        int m = s.size(), n = t.size();
        if(m != n) return 0;

        vector<int> freq(26, 0);
        for(int i = 0; i < n; i++){
            freq[s[i] - 'a']++;
            freq[t[i] - 'a']--;
        }

        for(auto it : freq){
            if(it != 0) return 0;
        }
        return 1;
    }
};
