class Solution {
public:
    int firstMissingPositive(vector<int>& nums) {
        int n = nums.size();
        sort(nums.begin(), nums.end());
        int count = 1;
        for (int i = 0; i < n; i++) {
            if (count == nums[i]) count++;
            else if (nums[i] > count) return count;
        }
        return count;
    }
};s
