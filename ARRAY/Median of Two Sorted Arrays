class Solution {
public:
    double findMedianSortedArrays(vector<int>& nums1, vector<int>& nums2) {
        int m = nums1.size(), n = nums2.size();
        vector<int> arr;
        for(int i = 0; i < m; i++){
            arr.push_back(nums1[i]);
        }
        for(int i = 0; i < n; i++){
            arr.push_back(nums2[i]);
        }

        sort(arr.begin(), arr.end());
        int x = m+n;
        if(x % 2 == 0) return (arr[x/2] +arr[x/2 - 1]) / 2.0;
        return arr[x/2];
    }
};
