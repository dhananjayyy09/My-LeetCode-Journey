class Solution {
public:
    int closestTarget(vector<string>& words, string target, int si) {
        int n = words.size();
        int dist = 1e9;
        for(int i = 0; i < n; i++){
            if(words[i] == target){
                dist = min({dist, (i-si+n) % n, (si-i+n) % n});
            }
        }
        return dist == 1e9 ? -1 : dist;
    }
};
