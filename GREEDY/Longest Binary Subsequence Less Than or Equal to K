class Solution {
public:
    int longestSubsequence(string s, int k) {
        int n = s.size();
        int len = 0;
        int base = 1, val = 0;
        
        for(int i = n-1; i >= 0; i--){
            if(s[i] == '0') len++;
            else if(base <= k){
                k -=  base;
                len++;
            }
            if(base <= k) base *= 2;
        }
        return len;
    }
};
