class Solution {
public:
    bool canReorderDoubled(vector<int>& arr) {
        int n = arr.size();
        unordered_map<int, int> mp;
        for(auto it : arr){
            mp[it]++;
        }

        sort(arr.begin(), arr.end(), [](int a, int b) {
            return abs(a) < abs(b);
        });

        for(auto x : arr){
            if(mp[x] == 0) continue;
            if (mp[2 * x] == 0) return false;
            mp[x]--;
            mp[2*x]--;
        }
        return true;
    }
};
