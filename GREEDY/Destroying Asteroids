class Solution {
public:
    bool asteroidsDestroyed(int mass, vector<int>& asteroids) {
        int n = asteroids.size();
        sort(asteroids.begin(), asteroids.end());
        long long curMass = mass;
        for(int i = 0; i < n; i++){
            if(asteroids[i] > curMass) return false;
            else curMass += asteroids[i];
        }
        return true;
    }
};
