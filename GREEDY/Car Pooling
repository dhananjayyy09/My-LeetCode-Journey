class Solution {
public:
    bool carPooling(vector<vector<int>>& trips, int capacity) {
        vector<pair<int, int>> events;
        for(auto &it : trips){
            events.push_back({it[1], it[0]});
            events.push_back({it[2], -it[0]});
        }

        sort(events.begin(), events.end());
        int psgr = 0;
        for(auto &it : events){
            psgr += it.second;
            if(psgr > capacity) return false; 
        } 
        return true;
    }
};
