class Solution {
public:
    int minimumPartition(string s, int k) {
        long long num = 0;
        int count = 1;
        for(char c : s){
            int digit = c - '0';
            if(digit > k) return -1;
            num = num * 10 + digit;
            if(num > k){
                count++;
                num = digit;
            }
        }
        return count;
    }
};
