class Solution {
public:
    int maxNumOfMarkedIndices(vector<int>& nums) {
        int n = nums.size();
        sort(nums.begin(), nums.end());
        int count = 0;
        int i = 0, j = n/2;
        while(i < n/2 && j < n){
            if(2 * nums[i] <= nums[j]){
                count += 2;
                i++;
            }
            j++;
        }
        return count;
    }
};
