class Solution {
public:
    long long largestPerimeter(vector<int>& nums) {
        int n = nums.size();
        sort(nums.begin(), nums.end());
        long long peri = -1;
        long long sum = 0;
        for(int i = 0; i < n; i++){
            sum += nums[i];
            if(i >= 2 && sum - nums[i] > nums[i]){
                peri = sum;
            }
        }
        return peri;
    }
};
