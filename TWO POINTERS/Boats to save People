class Solution {
public:
    int numRescueBoats(vector<int>& people, int limit) {
        int n = people.size();
        int ans = 0;
        sort(people.begin(), people.end());
        int l = 0, h = n-1;

        while(l <= h) {
            if(people[l] + people[h] <= limit){
                l++;
            }
            h--;
            ans++;
        }
        return ans;
    }
};
