class Solution {
public:
    int maxDistance(vector<int>& nums1, vector<int>& nums2) {
        int m = nums1.size(), n = nums2.size();
        int maxDis = 0;
        int i = 0, j = 0;
        while(i < m && j < n){
            while(j < n && nums1[i] <= nums2[j]){
                maxDis = max(j-i, maxDis);
                j++;
            }
            i++;
            j++;
        }
        return maxDis;
    }
};
