class Solution {
public:
    void dfs(int node, vector<vector<int>> &adj, vector<int> &vis){
        vis[node] = 1;
        for(auto &it : adj[node]){
            if(!vis[it]) dfs(it, adj, vis);
        }
    }

    bool canVisitAllRooms(vector<vector<int>>& rooms) {
        int n = rooms.size();
        vector<int> vis(n, 0);
        dfs(0, rooms, vis);

        for(auto &it : vis){
            if(!it) return false;
        }
        return 1;
    }
};
