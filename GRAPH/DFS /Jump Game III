class Solution {
public:
    bool solve(int i, vector<int> &vis, vector<int> &arr){
        int n = arr.size();
        if(i < 0 || i >= n || vis[i]) return 0;
        if(arr[i] == 0) return 1;
        vis[i] = 1;
        return solve(i - arr[i], vis, arr) || solve(i + arr[i], vis, arr);
    }

    bool canReach(vector<int>& arr, int start) {
        int n = arr.size();
        vector<int> vis(n, 0);
        return solve(start, vis, arr);
    }
};
