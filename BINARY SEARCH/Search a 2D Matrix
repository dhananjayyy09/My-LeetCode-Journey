class Solution {
public:
    bool searchMatrix(vector<vector<int>>& matrix, int target) {
        int m = matrix.size(), n = matrix[0].size();
        int r = 0, c = n-1;

        while(r < m && c >= 0){
            int curr = matrix[r][c];
            if(curr == target) return 1;
            else if(curr < target) r++;
            else c--;
        }
        return 0;
    }
};
